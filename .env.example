# ─── F.A.S.T. Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values before starting the server.

# Your Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Password Matt uses to log in to F.A.S.T.
FAST_PASSWORD=choose-a-strong-password

# Secret for signing login tokens — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate-a-random-64-char-string

# Claude model to use (update as new versions release)
CLAUDE_MODEL=claude-sonnet-4-6

# Port for the server (default 3001 in dev; hosting platforms often set this automatically)
PORT=3001

# In production, set this to the URL where the app is deployed (for CORS)
# CLIENT_ORIGIN=https://fast.stewardshipfinancial.com
